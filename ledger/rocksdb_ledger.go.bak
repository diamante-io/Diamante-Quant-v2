// ledger/rocksdbledger.go

package ledger

import (
	"crypto/sha256"
	"encoding/json"
	"errors"
	"fmt"
	"log"
	"os"
	"strconv"
	"sync"

	"diamante/common"
	"diamante/crypto"

	"github.com/tecbot/gorocksdb"
)

// RocksDBLedger is a production-level implementation of common.LedgerAPI using RocksDB.
type RocksDBLedger struct {
	db            *gorocksdb.DB
	ro            *gorocksdb.ReadOptions
	wo            *gorocksdb.WriteOptions
	mu            sync.RWMutex // Protects in-memory metadata
	currentHeight int
	logger        *log.Logger
}

// NewRocksDBLedger opens (or creates) a RocksDB instance at the given path.
func NewRocksDBLedger(path string) (*RocksDBLedger, error) {
	opts := gorocksdb.NewDefaultOptions()
	opts.SetCreateIfMissing(true)
	db, err := gorocksdb.OpenDb(opts, path)
	if err != nil {
		return nil, fmt.Errorf("failed to open RocksDB: %w", err)
	}
	ro := gorocksdb.NewDefaultReadOptions()
	wo := gorocksdb.NewDefaultWriteOptions()
	ldb := &RocksDBLedger{
		db: db,
		ro: ro,
		wo: wo,
		// Initialize a structured logger.
		logger: log.New(os.Stdout, "RocksDBLedger: ", log.Ldate|log.Ltime|log.Lshortfile),
	}
	// Try to read the last block height from meta.
	if lastBlockData, err := db.Get(ro, lastBlockKey()); err == nil {
		if lastBlockData.Size() > 0 {
			if height, convErr := strconv.Atoi(string(lastBlockData.Data())); convErr == nil {
				ldb.currentHeight = height
			} else {
				ldb.logger.Printf("Warning: unable to convert last block height: %v", convErr)
			}
		}
		lastBlockData.Free()
	} else {
		ldb.logger.Printf("Warning: failed to get last block metadata: %v", err)
	}
	ldb.logger.Printf("Initialized RocksDBLedger at path %s with currentHeight=%d", path, ldb.currentHeight)
	return ldb, nil
}

// Close closes the RocksDB instance.
func (l *RocksDBLedger) Close() {
	l.db.Close()
	l.ro.Destroy()
	l.wo.Destroy()
	l.logger.Println("RocksDBLedger closed")
}

// Key helper functions.
func accountKey(accountID string) []byte {
	return []byte("acct:" + accountID)
}

func transactionKey(txID string) []byte {
	return []byte("tx:" + txID)
}

func blockKey(blockNumber int) []byte {
	return []byte("block:" + strconv.Itoa(blockNumber))
}

func lastBlockKey() []byte {
	return []byte("meta:lastBlock")
}

// ------------------------
// LedgerAPI Implementation
// ------------------------

// CreateAccount creates a new account if it does not already exist.
func (l *RocksDBLedger) CreateAccount(ac *common.Account) error {
	key := accountKey(ac.ID)
	data, err := json.Marshal(ac)
	if err != nil {
		return fmt.Errorf("CreateAccount: failed to marshal account: %w", err)
	}
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		return fmt.Errorf("CreateAccount: failed to get account: %w", err)
	}
	defer slice.Free()
	if slice.Size() > 0 {
		return fmt.Errorf("CreateAccount: account %s already exists", ac.ID)
	}
	if err := l.db.Put(l.wo, key, data); err != nil {
		return fmt.Errorf("CreateAccount: failed to put account: %w", err)
	}
	l.logger.Printf("Account %s created", ac.ID)
	return nil
}

// UpdateAccount updates an existing account.
func (l *RocksDBLedger) UpdateAccount(ac *common.Account) error {
	key := accountKey(ac.ID)
	data, err := json.Marshal(ac)
	if err != nil {
		return fmt.Errorf("UpdateAccount: failed to marshal account: %w", err)
	}
	if err := l.db.Put(l.wo, key, data); err != nil {
		return fmt.Errorf("UpdateAccount: failed to update account: %w", err)
	}
	l.logger.Printf("Account %s updated", ac.ID)
	return nil
}

// GetBalance retrieves the balance for a given account.
func (l *RocksDBLedger) GetBalance(accountID string) (float64, error) {
	key := accountKey(accountID)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		return 0, fmt.Errorf("GetBalance: failed to get account: %w", err)
	}
	defer slice.Free()
	if slice.Size() == 0 {
		return 0, fmt.Errorf("GetBalance: account %s not found", accountID)
	}
	var ac common.Account
	if err := json.Unmarshal(slice.Data(), &ac); err != nil {
		return 0, fmt.Errorf("GetBalance: failed to unmarshal account: %w", err)
	}
	l.logger.Printf("Retrieved balance for account %s: %.2f", accountID, ac.Balance)
	return ac.Balance, nil
}

// UpdateAccountBalance retrieves an account, updates its balance, and writes it back.
func (l *RocksDBLedger) UpdateAccountBalance(accountID string, amount float64) error {
	key := accountKey(accountID)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		return fmt.Errorf("UpdateAccountBalance: failed to get account: %w", err)
	}
	defer slice.Free()
	if slice.Size() == 0 {
		return fmt.Errorf("UpdateAccountBalance: account %s does not exist", accountID)
	}
	var ac common.Account
	if err := json.Unmarshal(slice.Data(), &ac); err != nil {
		return fmt.Errorf("UpdateAccountBalance: failed to unmarshal account: %w", err)
	}
	if ac.Balance+amount < 0 {
		return fmt.Errorf("UpdateAccountBalance: insufficient funds in account %s", accountID)
	}
	ac.Balance += amount
	data, err := json.Marshal(ac)
	if err != nil {
		return fmt.Errorf("UpdateAccountBalance: failed to marshal account: %w", err)
	}
	if err := l.db.Put(l.wo, key, data); err != nil {
		return fmt.Errorf("UpdateAccountBalance: failed to update account: %w", err)
	}
	l.logger.Printf("Account %s balance updated to %.2f", accountID, ac.Balance)
	return nil
}

// AddTransaction validates and adds a transaction to the ledger.
func (l *RocksDBLedger) AddTransaction(tx common.Transaction) error {
	key := transactionKey(tx.ID)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		return fmt.Errorf("AddTransaction: failed to get transaction: %w", err)
	}
	defer slice.Free()
	if slice.Size() > 0 {
		return fmt.Errorf("AddTransaction: transaction %s already in ledger", tx.ID)
	}
	if err := l.validateTransaction(tx); err != nil {
		return fmt.Errorf("AddTransaction: transaction validation failed: %w", err)
	}
	data, err := json.Marshal(tx)
	if err != nil {
		return fmt.Errorf("AddTransaction: failed to marshal transaction: %w", err)
	}
	if err := l.db.Put(l.wo, key, data); err != nil {
		return fmt.Errorf("AddTransaction: failed to add transaction: %w", err)
	}
	l.logger.Printf("Transaction %s added to ledger", tx.ID)
	return nil
}

// IsTransactionCommitted checks whether a transaction exists in the ledger.
func (l *RocksDBLedger) IsTransactionCommitted(txID string) bool {
	key := transactionKey(txID)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		l.logger.Printf("IsTransactionCommitted: error getting transaction %s: %v", txID, err)
		return false
	}
	defer slice.Free()
	return slice.Size() > 0
}

// CommitBlock commits a block along with its transactions.
func (l *RocksDBLedger) CommitBlock(block common.Block) error {
	if block.Number <= 0 {
		return errors.New("CommitBlock: block number must be > 0")
	}
	key := blockKey(block.Number)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		return fmt.Errorf("CommitBlock: failed to get block: %w", err)
	}
	defer slice.Free()
	if slice.Size() > 0 {
		return fmt.Errorf("CommitBlock: block %d is already committed", block.Number)
	}
	if err := l.validateBlock(block); err != nil {
		return fmt.Errorf("CommitBlock: block validation failed: %w", err)
	}
	data, err := json.Marshal(block)
	if err != nil {
		return fmt.Errorf("CommitBlock: failed to marshal block: %w", err)
	}
	// Write block.
	if err := l.db.Put(l.wo, key, data); err != nil {
		return fmt.Errorf("CommitBlock: failed to commit block: %w", err)
	}
	// Also store all transactions of the block.
	for _, tx := range block.Transactions {
		txKey := transactionKey(tx.ID)
		txData, err := json.Marshal(tx)
		if err != nil {
			return fmt.Errorf("CommitBlock: failed to marshal transaction %s: %w", tx.ID, err)
		}
		if err := l.db.Put(l.wo, txKey, txData); err != nil {
			return fmt.Errorf("CommitBlock: failed to commit transaction %s: %w", tx.ID, err)
		}
	}
	l.mu.Lock()
	if block.Number > l.currentHeight {
		l.currentHeight = block.Number
	}
	l.mu.Unlock()
	// Persist meta information.
	if err := l.db.Put(l.wo, lastBlockKey(), []byte(strconv.Itoa(block.Number))); err != nil {
		return fmt.Errorf("CommitBlock: failed to update last block metadata: %w", err)
	}
	l.logger.Printf("Committed block #%d with %d transactions", block.Number, len(block.Transactions))
	return nil
}

// GetLastBlockHash retrieves the hash of the most recent block.
func (l *RocksDBLedger) GetLastBlockHash() (string, error) {
	l.mu.RLock()
	height := l.currentHeight
	l.mu.RUnlock()
	if height == 0 {
		return "", errors.New("GetLastBlockHash: no blocks committed yet")
	}
	block, exists := l.GetBlockByNumber(height)
	if !exists {
		return "", fmt.Errorf("GetLastBlockHash: block %d not found", height)
	}
	hash := l.computeBlockHash(block)
	l.logger.Printf("Last block hash for block %d: %s", height, hash)
	return hash, nil
}

// GetBlockByNumber retrieves a block by its number.
func (l *RocksDBLedger) GetBlockByNumber(num int) (common.Block, bool) {
	key := blockKey(num)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		l.logger.Printf("GetBlockByNumber: error retrieving block %d: %v", num, err)
		return common.Block{}, false
	}
	defer slice.Free()
	if slice.Size() == 0 {
		return common.Block{}, false
	}
	var block common.Block
	if err := json.Unmarshal(slice.Data(), &block); err != nil {
		l.logger.Printf("GetBlockByNumber: failed to unmarshal block %d: %v", num, err)
		return common.Block{}, false
	}
	return block, true
}

// CreateSnapshot generates a snapshot of all account states at the given block height.
func (l *RocksDBLedger) CreateSnapshot(height int) error {
	l.mu.RLock()
	defer l.mu.RUnlock()

	it := l.db.NewIterator(l.ro)
	defer it.Close()
	snapshotData := make(map[string]interface{})
	prefix := []byte("acct:")
	for it.Seek(prefix); it.ValidForPrefix(prefix); it.Next() {
		key := it.Key()
		value := it.Value()
		accountID := string(key.Data()[len(prefix):])
		var account common.Account
		if err := json.Unmarshal(value.Data(), &account); err != nil {
			key.Free()
			value.Free()
			return fmt.Errorf("CreateSnapshot: failed to unmarshal account %s: %w", accountID, err)
		}
		snapshotData[accountID] = account
		key.Free()
		value.Free()
	}
	snapshotKey := []byte("meta:snapshot:" + strconv.Itoa(height))
	snapshotJSON, err := json.Marshal(snapshotData)
	if err != nil {
		return fmt.Errorf("CreateSnapshot: failed to marshal snapshot data: %w", err)
	}
	if err := l.db.Put(l.wo, snapshotKey, snapshotJSON); err != nil {
		return fmt.Errorf("CreateSnapshot: failed to store snapshot: %w", err)
	}
	l.logger.Printf("Snapshot created at height %d", height)
	return nil
}

// RestoreSnapshot restores the ledger state from the snapshot at the given block height.
func (l *RocksDBLedger) RestoreSnapshot(height int) error {
	l.mu.Lock()
	defer l.mu.Unlock()

	snapshotKey := []byte("meta:snapshot:" + strconv.Itoa(height))
	slice, err := l.db.Get(l.ro, snapshotKey)
	if err != nil {
		return fmt.Errorf("RestoreSnapshot: failed to get snapshot: %w", err)
	}
	defer slice.Free()
	if slice.Size() == 0 {
		return fmt.Errorf("RestoreSnapshot: snapshot at height %d not found", height)
	}
	var snapshotData map[string]common.Account
	if err := json.Unmarshal(slice.Data(), &snapshotData); err != nil {
		return fmt.Errorf("RestoreSnapshot: failed to unmarshal snapshot data: %w", err)
	}
	for accountID, account := range snapshotData {
		key := accountKey(accountID)
		data, err := json.Marshal(account)
		if err != nil {
			return fmt.Errorf("RestoreSnapshot: failed to marshal account %s: %w", accountID, err)
		}
		if err := l.db.Put(l.wo, key, data); err != nil {
			return fmt.Errorf("RestoreSnapshot: failed to restore account %s: %w", accountID, err)
		}
	}
	l.currentHeight = height
	if err := l.db.Put(l.wo, lastBlockKey(), []byte(strconv.Itoa(height))); err != nil {
		return fmt.Errorf("RestoreSnapshot: failed to update last block metadata: %w", err)
	}
	l.logger.Printf("Snapshot restored at height %d", height)
	return nil
}

// IntegrityCheck performs a basic integrity check.
func (l *RocksDBLedger) IntegrityCheck() error {
	slice, err := l.db.Get(l.ro, lastBlockKey())
	if err != nil {
		return fmt.Errorf("IntegrityCheck: error retrieving last block key: %w", err)
	}
	defer slice.Free()
	if slice.Size() == 0 {
		return errors.New("IntegrityCheck: missing last block metadata")
	}
	l.logger.Println("Integrity check passed")
	return nil
}

// --- Smart Contract Methods ---

func (l *RocksDBLedger) DeploySmartContract(sc *common.SmartContract) error {
	data, err := json.Marshal(sc)
	if err != nil {
		return fmt.Errorf("DeploySmartContract: failed to marshal smart contract: %w", err)
	}
	key := []byte("sc:" + sc.ID)
	if err := l.db.Put(l.wo, key, data); err != nil {
		return fmt.Errorf("DeploySmartContract: failed to deploy smart contract: %w", err)
	}
	l.logger.Printf("Smart contract %s deployed", sc.ID)
	return nil
}

func (l *RocksDBLedger) ExecuteSmartContract(scID, function, sender string, params map[string]interface{}) (interface{}, error) {
	key := []byte("sc:" + scID)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		return nil, fmt.Errorf("ExecuteSmartContract: failed to get smart contract %s: %w", scID, err)
	}
	defer slice.Free()
	if slice.Size() == 0 {
		return nil, fmt.Errorf("ExecuteSmartContract: smart contract %s not found", scID)
	}
	var sc common.SmartContract
	if err := json.Unmarshal(slice.Data(), &sc); err != nil {
		return nil, fmt.Errorf("ExecuteSmartContract: failed to unmarshal smart contract %s: %w", scID, err)
	}
	l.logger.Printf("Executing smart contract %s, function %s by %s", scID, function, sender)
	// Simulated execution result.
	result := fmt.Sprintf("Executed function %s with params %v", function, params)
	return result, nil
}

func (l *RocksDBLedger) RemoveSmartContract(contractID string) error {
	key := []byte("sc:" + contractID)
	if err := l.db.Delete(l.wo, key); err != nil {
		return fmt.Errorf("RemoveSmartContract: failed to remove smart contract %s: %w", contractID, err)
	}
	l.logger.Printf("Smart contract %s removed", contractID)
	return nil
}

// --- Internal Helper Methods ---

func (l *RocksDBLedger) validateTransaction(tx common.Transaction) error {
	key := accountKey(tx.Sender)
	slice, err := l.db.Get(l.ro, key)
	if err != nil {
		return fmt.Errorf("validateTransaction: failed to get sender account: %w", err)
	}
	defer slice.Free()
	if slice.Size() == 0 {
		return fmt.Errorf("validateTransaction: sender account %s does not exist", tx.Sender)
	}
	var ac common.Account
	if err := json.Unmarshal(slice.Data(), &ac); err != nil {
		return fmt.Errorf("validateTransaction: failed to unmarshal sender account: %w", err)
	}
	if ac.Balance < tx.Amount+tx.Fee {
		return fmt.Errorf("validateTransaction: insufficient balance in account %s", tx.Sender)
	}
	// Skip signature check for fake test signature.
	if isFakeTestSignature(tx.Signature) {
		return nil
	}
	valid, err := crypto.VerifySignature(ac.PublicKey, []byte(tx.ID), tx.Signature)
	if err != nil {
		return fmt.Errorf("validateTransaction: transaction signature error: %w", err)
	}
	if !valid {
		return fmt.Errorf("validateTransaction: invalid signature for transaction %s", tx.ID)
	}
	return nil
}

func (l *RocksDBLedger) validateBlock(block common.Block) error {
	if block.Number > 1 {
		prevBlock, exists := l.GetBlockByNumber(block.Number - 1)
		if !exists {
			return fmt.Errorf("validateBlock: previous block not found for block #%d", block.Number)
		}
		if block.PreviousHash != l.computeBlockHash(prevBlock) {
			return fmt.Errorf("validateBlock: block #%d previous hash mismatch", block.Number)
		}
	}
	for _, tx := range block.Transactions {
		if err := l.validateTransaction(tx); err != nil {
			return fmt.Errorf("validateBlock: block #%d invalid transaction %s: %v", block.Number, tx.ID, err)
		}
	}
	if block.Number == 1 {
		return nil
	}
	computed := l.computeBlockHash(block)
	if computed != block.Hash {
		return fmt.Errorf("validateBlock: block #%d: computed hash %s does not match expected hash %s", block.Number, computed, block.Hash)
	}
	return nil
}

func (l *RocksDBLedger) computeBlockHash(block common.Block) string {
	data := fmt.Sprintf("%d:%s:%d", block.Number, block.PreviousHash, block.Timestamp)
	sum := sha256.Sum256([]byte(data))
	return fmt.Sprintf("%x", sum[:])
}

func isFakeTestSignature(sig []byte) bool {
	return len(sig) == 3 && sig[0] == 0x01 && sig[1] == 0x02 && sig[2] == 0x03
}
