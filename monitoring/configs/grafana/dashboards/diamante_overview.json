{
  "title": "Diamante Overview",
  "uid": "diamante-overview",
  "version": 1,
  "timezone": "browser",
  "panels": [
    {
      "type": "graph",
      "title": "Block Height",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "diamante_consensus_block_height",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Network Load (TPS)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "diamante_tps",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Peer Count",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "diamante_peer_count",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Transaction Pool Size",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "diamante_tx_pool_size",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "graph",
      "title": "Consensus Round Time",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "diamante_consensus_round_time_seconds",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Storage Operations",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "diamante_storage_operations",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ]
}
