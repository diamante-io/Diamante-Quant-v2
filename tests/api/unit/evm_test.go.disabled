// Mock EVM runtime
type mockEVMRuntime struct {
	mock.Mock
}

func (m *mockEVMRuntime) DeployContract(code []byte, args []byte, gasLimit uint64) (string, error) {
	mockArgs := m.Called(code, args, gasLimit)
	return mockArgs.String(0), mockArgs.Error(1)
}

func (m *mockEVMRuntime) CallContract(address string, data []byte, gasLimit uint64) ([]byte, error) {
	mockArgs := m.Called(address, data, gasLimit)
	if mockArgs.Get(0) == nil {
		return nil, mockArgs.Error(1)
	}
	return mockArgs.Get(0).([]byte), mockArgs.Error(1)
}

func (m *mockEVMRuntime) GetCode(address string) ([]byte, error) {
	mockArgs := m.Called(address)
	if mockArgs.Get(0) == nil {
		return nil, mockArgs.Error(1)
	}
	return mockArgs.Get(0).([]byte), mockArgs.Error(1)
}

func (m *mockEVMRuntime) GetStorage(address string, key string) ([]byte, error) {
	mockArgs := m.Called(address, key)
	if mockArgs.Get(0) == nil {
		return nil, mockArgs.Error(1)
	}
	return mockArgs.Get(0).([]byte), mockArgs.Error(1)
}

func (m *mockEVMRuntime) EstimateGas(from, to string, data []byte, value uint64) (uint64, error) {
	mockArgs := m.Called(from, to, data, value)
	return mockArgs.Get(0).(uint64), mockArgs.Error(1)
}

func (m *mockEVMRuntime) GetTransactionReceipt(hash string) (*ethtypes.Receipt, error) {
	mockArgs := m.Called(hash)
	if mockArgs.Get(0) == nil {
		return nil, mockArgs.Error(1)
	}
	return mockArgs.Get(0).(*ethtypes.Receipt), mockArgs.Error(1)
}

func (m *mockEVMRuntime) GetBlockByNumber(number uint64) (*ethtypes.Block, error) {
	mockArgs := m.Called(number)
	if mockArgs.Get(0) == nil {
