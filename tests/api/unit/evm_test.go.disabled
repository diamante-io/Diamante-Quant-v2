func (m *mockEVMRuntime) GetLatestBlock() (*ethtypes.Block, error) {
	mockArgs := m.Called()
	if mockArgs.Get(0) == nil {
		return nil, mockArgs.Error(1)
	}
	return mockArgs.Get(0).(*ethtypes.Block), mockArgs.Error(1)
}

func (m *mockEVMRuntime) SendTransaction(tx *ethtypes.Transaction) error {
	mockArgs := m.Called(tx)
	return mockArgs.Error(0)
}

func (m *mockEVMRuntime) GetBalance(address string) (uint64, error) {
	mockArgs := m.Called(address)
	return mockArgs.Get(0).(uint64), mockArgs.Error(1)
}

func (m *mockEVMRuntime) GetNonce(address string) (uint64, error) {
	mockArgs := m.Called(address)
	return mockArgs.Get(0).(uint64), mockArgs.Error(1)
}

func (m *mockEVMRuntime) GetGasPrice() (uint64, error) {
	mockArgs := m.Called()
	return mockArgs.Get(0).(uint64), mockArgs.Error(1)
}

func (m *mockEVMRuntime) CreateAccessList(from, to string, data []byte, gasLimit uint64) (*ethtypes.AccessList, uint64, error) {
	mockArgs := m.Called(from, to, data, gasLimit)
	if mockArgs.Get(0) == nil {
		return nil, mockArgs.Get(1).(uint64), mockArgs.Error(2)
	}
	return mockArgs.Get(0).(*ethtypes.AccessList), mockArgs.Get(1).(uint64), mockArgs.Error(2)
}

// Test setup for EVM tests
func setupTestAPIWithEVM(t *testing.T) (*api.API, *mockStorage, *mockConsensus, *mockLedger, *mockTransactionPool, *mockWalletManager, *mockEVMRuntime) {
	apiServer, mockStore, mockCon, mockLed, mockTxPool, mockWM := setupTestAPI(t)
	mockEVM := &mockEVMRuntime{}
	
	// Replace the EVM runtime in the API server
	apiServer.SetEVMRuntime(mockEVM)
	
	return apiServer, mockStore, mockCon, mockLed, mockTxPool, mockWM, mockEVM
}

func TestEVM_HandleETHCall(t *testing.T) {
	apiServer, _, _, _, _, _, mockEVM := setupTestAPIWithEVM(t)

	testData := []byte{0x12, 0x34, 0x56, 0x78}
	testResult := []byte{0xab, 0xcd, 0xef}

	// Setup mock
	mockEVM.On("CallContract", "0x1234567890abcdef", testData, uint64(1000000)).Return(testResult, nil)

	// Create JSON-RPC request
	reqBody := map[string]interface{}{
		"jsonrpc": "2.0",
		"method":  "eth_call",
		"params": []interface{}{
			map[string]interface{}{
				"to":   "0x1234567890abcdef",
				"data": hexutil.Encode(testData),
				"gas":  hexutil.EncodeUint64(1000000),
			},
			"latest",
		},
		"id": 1,
	}
	body, _ := json.Marshal(reqBody)

	// Create request
	req, err := http.NewRequest("POST", "/evm", bytes.NewBuffer(body))
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")
	req.Header.Set("Content-Type", "application/json")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, "2.0", response["jsonrpc"])
	assert.Equal(t, float64(1), response["id"])
	assert.Equal(t, hexutil.Encode(testResult), response["result"])

	// Verify mock calls
	mockEVM.AssertExpectations(t)
}

