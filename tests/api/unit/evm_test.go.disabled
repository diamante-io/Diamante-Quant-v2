func TestEVM_BatchRequests(t *testing.T) {
	apiServer, _, _, _, _, _, mockEVM := setupTestAPIWithEVM(t)

	// Setup mocks for batch requests
	mockEVM.On("GetBalance", "0xaddr1").Return(uint64(1000), nil)
	mockEVM.On("GetNonce", "0xaddr1").Return(uint64(5), nil)
	mockEVM.On("GetGasPrice").Return(uint64(20000000000), nil)

	// Create batch JSON-RPC request
	batchReq := []map[string]interface{}{
		{
			"jsonrpc": "2.0",
			"method":  "eth_getBalance",
			"params":  []interface{}{"0xaddr1", "latest"},
			"id":      1,
		},
		{
			"jsonrpc": "2.0",
			"method":  "eth_getTransactionCount",
			"params":  []interface{}{"0xaddr1", "latest"},
			"id":      2,
		},
		{
			"jsonrpc": "2.0",
			"method":  "eth_gasPrice",
			"params":  []interface{}{},
			"id":      3,
		},
	}
	body, _ := json.Marshal(batchReq)

	// Create request
	req, err := http.NewRequest("POST", "/evm", bytes.NewBuffer(body))
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")
	req.Header.Set("Content-Type", "application/json")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var responses []map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &responses)
	require.NoError(t, err)

	assert.Len(t, responses, 3)
	assert.Equal(t, float64(1), responses[0]["id"])
	assert.Equal(t, hexutil.EncodeUint64(1000), responses[0]["result"])
	assert.Equal(t, float64(2), responses[1]["id"])
	assert.Equal(t, hexutil.EncodeUint64(5), responses[1]["result"])
	assert.Equal(t, float64(3), responses[2]["id"])
	assert.Equal(t, hexutil.EncodeUint64(20000000000), responses[2]["result"])

	// Verify mock calls
	mockEVM.AssertExpectations(t)
}

func TestEVM_ErrorHandling(t *testing.T) {
	apiServer, _, _, _, _, _, mockEVM := setupTestAPIWithEVM(t)

	// Setup mock to return error
	mockEVM.On("GetBalance", "0xinvalid").Return(uint64(0), evm.ErrInvalidAddress)

	// Create JSON-RPC request
	reqBody := map[string]interface{}{
		"jsonrpc": "2.0",
		"method":  "eth_getBalance",
		"params":  []interface{}{"0xinvalid", "latest"},
		"id":      1,
	}
	body, _ := json.Marshal(reqBody)

	// Create request
	req, err := http.NewRequest("POST", "/evm", bytes.NewBuffer(body))
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")
	req.Header.Set("Content-Type", "application/json")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code) // JSON-RPC errors still return 200

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, "2.0", response["jsonrpc"])
	assert.Equal(t, float64(1), response["id"])
	assert.NotNil(t, response["error"])

	errorObj := response["error"].(map[string]interface{})
	assert.Equal(t, float64(-32602), errorObj["code"]) // Invalid params
	assert.Contains(t, errorObj["message"], "invalid")

	// Verify mock calls
	mockEVM.AssertExpectations(t)
}

func TestEVM_InvalidMethod(t *testing.T) {
	apiServer, _, _, _, _, _, _ := setupTestAPIWithEVM(t)

	// Create JSON-RPC request with invalid method
	reqBody := map[string]interface{}{
		"jsonrpc": "2.0",
		"method":  "eth_invalidMethod",
		"params":  []interface{}{},
		"id":      1,
	}
	body, _ := json.Marshal(reqBody)

	// Create request
	req, err := http.NewRequest("POST", "/evm", bytes.NewBuffer(body))
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")
	req.Header.Set("Content-Type", "application/json")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.NotNil(t, response["error"])
	errorObj := response["error"].(map[string]interface{})
	assert.Equal(t, float64(-32601), errorObj["code"]) // Method not found
}

func TestEVM_DeployContract(t *testing.T) {
	apiServer, _, _, _, _, _, mockEVM := setupTestAPIWithEVM(t)

	contractCode := []byte{0x60, 0x80, 0x60, 0x40} // Sample contract bytecode
	contractAddress := "0xdeployed123"

	// Setup mock
	mockEVM.On("DeployContract", contractCode, []byte{}, uint64(3000000)).Return(contractAddress, nil)

	// Create request
	reqBody := map[string]interface{}{
		"code":     hexutil.Encode(contractCode),
		"gasLimit": 3000000,
	}
	body, _ := json.Marshal(reqBody)

	req, err := http.NewRequest("POST", "/evm/deploy", bytes.NewBuffer(body))
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")
	req.Header.Set("Content-Type", "application/json")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusCreated, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, contractAddress, response["address"])
	assert.Equal(t, "Contract deployed successfully", response["message"])

	// Verify mock calls
	mockEVM.AssertExpectations(t)
}