// Test setup helper
func setupTestAPI(t *testing.T) (*api.API, *mockStorage, *mockConsensus, *mockLedger, *mockTransactionPool, *mockWalletManager) {
	mockStore := &mockStorage{}
	mockCon := &mockConsensus{}
	mockLed := &mockLedger{}
	mockTxPool := &mockTransactionPool{}
	mockWM := &mockWalletManager{}

	// Create test config and logger
	logger := logrus.New()
	testConfig := &config.Config{}
	mockGov := (*governance.Governance)(nil) // Nil governance for test
	healthFn := func() int { return 1 } // Simple health function

	// Create API with correct signature
	apiServer := api.NewAPI(
		mockLed,        // LedgerAPI
		mockCon,        // Consensus
		nil,            // TransactionManager (nil for now)
		mockStore,      // LedgerStore
		mockGov,        // Governance
		logger,         // Logger
		testConfig,     // Config
		healthFn,       // Health function
	)

	return apiServer, mockStore, mockCon, mockLed, mockTxPool, mockWM
}

// Test cases

func TestAPI_HandleStatus(t *testing.T) {
	apiServer, mockStore, mockCon, _, mockTxPool, _ := setupTestAPI(t)

	// Setup mocks
	mockStore.On("CheckHealth").Return(nil)
	mockCon.On("GetCurrentHeight").Return(uint64(100))
	// mockCon.On("GetConsensusState").Return(consensus.StateRunning) - removed, not in interface
	mockTxPool.On("Size").Return(50)

	// Create request
	req, err := http.NewRequest("GET", "/status", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, "ok", response["status"])
	assert.Equal(t, float64(100), response["height"])
	assert.Equal(t, float64(50), response["pending_transactions"])

	// Verify mock calls
	mockStore.AssertExpectations(t)
	mockCon.AssertExpectations(t)
	mockTxPool.AssertExpectations(t)
}

func TestAPI_HandleGetAccount(t *testing.T) {
	apiServer, mockStore, _, mockLed, _, _ := setupTestAPI(t)

	testAddress := "0x1234567890abcdef"
	testAccount := common.Account{
		ID:      testAddress,
		Balance: 1000000,
		Nonce:   5,
	}

	// Setup mocks
	mockStore.On("GetAccount", testAddress).Return(testAccount, nil)
	mockLed.On("GetAccount", testAddress).Return(common.Account{
		ID:      testAddress,
		Balance: 1000000,
		Nonce:   5,
	}, nil)

	// Create request
	req, err := http.NewRequest("GET", fmt.Sprintf("/accounts/%s", testAddress), nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, testAddress, response["address"])
	assert.Equal(t, float64(1000000), response["balance"])
	assert.Equal(t, float64(5), response["nonce"])

	// Verify mock calls
	mockStore.AssertExpectations(t)
	mockLed.AssertExpectations(t)
}

func TestAPI_HandleGetBlock(t *testing.T) {
	apiServer, mockStore, _, _, _, _ := setupTestAPI(t)

	testBlock := common.Block{
		Number:    100,
		Hash:      "0xabcdef",
		Timestamp: time.Now().Unix(),
		Transactions: []common.Transaction{
			{
				ID:       "0x123",
				Sender:   "0xaaa",
				Receiver: "0xbbb",
				Amount:   100,
			},
		},
	}

	// Setup mocks
	mockStore.On("GetBlock", uint64(100)).Return(testBlock, nil)

	// Create request
	req, err := http.NewRequest("GET", "/blocks/100", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, float64(100), response["height"])
	assert.Equal(t, "0xabcdef", response["hash"])
	assert.NotNil(t, response["transactions"])

	// Verify mock calls
	mockStore.AssertExpectations(t)
}

func TestAPI_HandleCreateWallet(t *testing.T) {
	apiServer, _, _, _, _, mockWM := setupTestAPI(t)

	testWallet := &wallet.Wallet{
		ID: "wallet-123",
	}

	// Setup mocks
	mockWM.On("CreateWallet", "test-password").Return(testWallet, nil)

	// Create request body
	reqBody := map[string]string{
		"password": "test-password",
	}
	body, _ := json.Marshal(reqBody)

	// Create request
	req, err := http.NewRequest("POST", "/wallets", bytes.NewBuffer(body))
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")
	req.Header.Set("Content-Type", "application/json")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusCreated, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, "wallet-123", response["id"])
	assert.Equal(t, "0xwallet123", response["address"])

	// Verify mock calls
	mockWM.AssertExpectations(t)
}

func TestAPI_RateLimiting(t *testing.T) {
	apiServer, mockStore, mockCon, _, mockTxPool, _ := setupTestAPI(t)

	// Setup mocks for multiple calls
	mockStore.On("CheckHealth").Return(nil)
	mockCon.On("GetCurrentHeight").Return(uint64(100))
	// mockCon.On("GetConsensusState").Return(consensus.StateRunning) - removed, not in interface
	mockTxPool.On("Size").Return(50)

	// Create router
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)

	// Make requests up to rate limit
	for i := 0; i < 100; i++ {
		req, err := http.NewRequest("GET", "/status", nil)
		require.NoError(t, err)
		req.Header.Set("Authorization", "Bearer test-token")

		rr := httptest.NewRecorder()
		router.ServeHTTP(rr, req)

		assert.Equal(t, http.StatusOK, rr.Code)
	}

	// Next request should be rate limited
	req, err := http.NewRequest("GET", "/status", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	rr := httptest.NewRecorder()
	router.ServeHTTP(rr, req)

	assert.Equal(t, http.StatusTooManyRequests, rr.Code)
}

func TestAPI_Authentication(t *testing.T) {
	apiServer, _, _, _, _, _ := setupTestAPI(t)

	testCases := []struct {
		name           string
		authHeader     string
		expectedStatus int
	}{
		{
			name:           "Valid Bearer Token",
			authHeader:     "Bearer test-token",
			expectedStatus: http.StatusOK,
		},
		{
			name:           "Valid API Key",
			authHeader:     "test-api-key",
			expectedStatus: http.StatusOK,
		},
		{
			name:           "Invalid Token",
			authHeader:     "Bearer invalid-token",
			expectedStatus: http.StatusUnauthorized,
		},
		{
			name:           "No Auth Header",
			authHeader:     "",
			expectedStatus: http.StatusUnauthorized,
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			req, err := http.NewRequest("GET", "/health", nil)
			require.NoError(t, err)

			if tc.authHeader != "" {
				req.Header.Set("Authorization", tc.authHeader)
			}

			rr := httptest.NewRecorder()
			router := mux.NewRouter()
			apiServer.SetupRoutes(router)
			router.ServeHTTP(rr, req)

			assert.Equal(t, tc.expectedStatus, rr.Code)
		})
	}
}

func TestAPI_ErrorHandling(t *testing.T) {
	apiServer, mockStore, _, _, _, _ := setupTestAPI(t)

	// Test storage error
	mockStore.On("GetBlock", uint64(999)).Return(common.Block{}, fmt.Errorf("block not found"))

	req, err := http.NewRequest("GET", "/blocks/999", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	rr := httptest.NewRecorder()
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	assert.Equal(t, http.StatusNotFound, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)
	assert.Contains(t, response["error"], "not found")

	mockStore.AssertExpectations(t)
}

func TestAPI_CORS(t *testing.T) {
	apiServer, _, _, _, _, _ := setupTestAPI(t)

	req, err := http.NewRequest("OPTIONS", "/status", nil)
	require.NoError(t, err)
	req.Header.Set("Origin", "http://localhost:3000")
	req.Header.Set("Access-Control-Request-Method", "GET")

	rr := httptest.NewRecorder()
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	assert.Equal(t, http.StatusOK, rr.Code)
	assert.Equal(t, "*", rr.Header().Get("Access-Control-Allow-Origin"))
	assert.Contains(t, rr.Header().Get("Access-Control-Allow-Methods"), "GET")
}