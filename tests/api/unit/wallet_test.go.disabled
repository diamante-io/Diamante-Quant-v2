func TestWallet_HandleCreateWallet(t *testing.T) {
	apiServer, _, _, _, _, mockWM := setupTestAPI(t)

	testCases := []struct {
		name           string
		requestBody    map[string]interface{}
		expectedStatus int
		setupMocks     func()
		checkResponse  func(t *testing.T, response map[string]interface{})
	}{
		{
			name: "Create with password",
			requestBody: map[string]interface{}{
				"password": "secure-password-123",
			},
			expectedStatus: http.StatusCreated,
			setupMocks: func() {
				mockWM.On("CreateWallet", "secure-password-123").Return(&wallet.Wallet{
					ID:       "wallet-123",
					Address:  "0xnewwallet",
					Mnemonic: "test mnemonic phrase",
				}, nil)
			},
			checkResponse: func(t *testing.T, response map[string]interface{}) {
				assert.Equal(t, "wallet-123", response["id"])
				assert.Equal(t, "0xnewwallet", response["address"])
				assert.NotEmpty(t, response["mnemonic"])
			},
		},
		{
			name: "Import with mnemonic",
			requestBody: map[string]interface{}{
				"password": "password123",
				"mnemonic": "abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about",
			},
			expectedStatus: http.StatusCreated,
			setupMocks: func() {
				mockWM.On("ImportWallet", 
					"abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about",
					"password123",
				).Return(&wallet.Wallet{
					ID:      "imported-wallet",
					Address: "0ximported",
				}, nil)
			},
			checkResponse: func(t *testing.T, response map[string]interface{}) {
				assert.Equal(t, "imported-wallet", response["id"])
				assert.Equal(t, "0ximported", response["address"])
			},
		},
		{
			name: "Missing password",
			requestBody: map[string]interface{}{},
			expectedStatus: http.StatusBadRequest,
			setupMocks: func() {},
			checkResponse: func(t *testing.T, response map[string]interface{}) {
				assert.Contains(t, response["error"], "password")
			},
		},
		{
			name: "Invalid mnemonic",
			requestBody: map[string]interface{}{
				"password": "password123",
				"mnemonic": "invalid mnemonic phrase",
			},
			expectedStatus: http.StatusBadRequest,
			setupMocks: func() {
				mockWM.On("ImportWallet", "invalid mnemonic phrase", "password123").
					Return(nil, wallet.ErrInvalidMnemonic)
			},
			checkResponse: func(t *testing.T, response map[string]interface{}) {
				assert.Contains(t, response["error"], "mnemonic")
			},
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			tc.setupMocks()

			body, _ := json.Marshal(tc.requestBody)
			req, err := http.NewRequest("POST", "/wallets", bytes.NewBuffer(body))
			require.NoError(t, err)
			req.Header.Set("Authorization", "Bearer test-token")
			req.Header.Set("Content-Type", "application/json")

			rr := httptest.NewRecorder()
			router := mux.NewRouter()
			apiServer.SetupRoutes(router)
			router.ServeHTTP(rr, req)

			assert.Equal(t, tc.expectedStatus, rr.Code)

			var response map[string]interface{}
			err = json.Unmarshal(rr.Body.Bytes(), &response)
			require.NoError(t, err)

			tc.checkResponse(t, response)
		})
	}

	mockWM.AssertExpectations(t)
}

func TestAPI_HandleGetWallet(t *testing.T) {
	apiServer, _, _, _, _, mockWM := setupTestAPI(t)

	testWallet := &wallet.Wallet{
		ID:        "wallet-123",
		Address:   "0xwallet123",
		PublicKey: "0xpubkey",
		CreatedAt: 1234567890,
	}

	// Setup mock
	mockWM.On("GetWallet", "wallet-123").Return(testWallet, nil)
	mockWM.On("GetWallet", "nonexistent").Return(nil, wallet.ErrWalletNotFound)

	// Test successful get
	req, err := http.NewRequest("GET", "/wallets/wallet-123", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	rr := httptest.NewRecorder()
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, "wallet-123", response["id"])
	assert.Equal(t, "0xwallet123", response["address"])
	assert.Equal(t, "0xpubkey", response["publicKey"])

	// Test wallet not found
	req2, err := http.NewRequest("GET", "/wallets/nonexistent", nil)
	require.NoError(t, err)
	req2.Header.Set("Authorization", "Bearer test-token")

	rr2 := httptest.NewRecorder()
	router.ServeHTTP(rr2, req2)

	assert.Equal(t, http.StatusNotFound, rr2.Code)

	mockWM.AssertExpectations(t)
}

func TestAPI_HandleListWallets(t *testing.T) {
	apiServer, _, _, _, _, mockWM := setupTestAPI(t)

	testWallets := []*wallet.Wallet{
		{
			ID:      "wallet-1",
			Address: "0xwallet1",
		},
		{
			ID:      "wallet-2",
			Address: "0xwallet2",
		},
		{
			ID:      "wallet-3",
			Address: "0xwallet3",
		},
	}

	// Setup mock
	mockWM.On("ListWallets").Return(testWallets, nil)

	// Create request
	req, err := http.NewRequest("GET", "/wallets", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response struct {
		Wallets []map[string]interface{} `json:"wallets"`
		Count   int                      `json:"count"`
	}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, 3, response.Count)
	assert.Len(t, response.Wallets, 3)
	assert.Equal(t, "wallet-1", response.Wallets[0]["id"])
	assert.Equal(t, "wallet-2", response.Wallets[1]["id"])
	assert.Equal(t, "wallet-3", response.Wallets[2]["id"])

	mockWM.AssertExpectations(t)
}

func TestAPI_HandleDeleteWallet(t *testing.T) {
	apiServer, _, _, _, _, mockWM := setupTestAPI(t)

	// Setup mocks
	mockWM.On("DeleteWallet", "wallet-123").Return(nil)
	mockWM.On("DeleteWallet", "nonexistent").Return(wallet.ErrWalletNotFound)

	// Test successful deletion
	req, err := http.NewRequest("DELETE", "/wallets/wallet-123", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	rr := httptest.NewRecorder()
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)
	assert.Equal(t, "Wallet deleted successfully", response["message"])

	// Test wallet not found
	req2, err := http.NewRequest("DELETE", "/wallets/nonexistent", nil)
	require.NoError(t, err)
	req2.Header.Set("Authorization", "Bearer test-token")

	rr2 := httptest.NewRecorder()
	router.ServeHTTP(rr2, req2)

	assert.Equal(t, http.StatusNotFound, rr2.Code)

	mockWM.AssertExpectations(t)
}

