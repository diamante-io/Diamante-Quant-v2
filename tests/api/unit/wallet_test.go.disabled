	testWallet := &wallet.Wallet{
		ID:      "wallet-123",
		Address: "0xwallet123",
	}

	// Setup mocks
	mockWM.On("GetWallet", "wallet-123").Return(testWallet, nil)
	mockLed.On("GetBalance", "0xwallet123").Return(uint64(1000000), nil)

	// Create request
