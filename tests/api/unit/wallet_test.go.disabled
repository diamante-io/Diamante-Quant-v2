	mockLed.AssertExpectations(t)
}

func TestAPI_WalletSecurity(t *testing.T) {
	apiServer, _, _, _, _, mockWM := setupTestAPI(t)

	// Test that sensitive data is not exposed
	sensitiveWallet := &wallet.Wallet{
		ID:         "wallet-sec",
		Address:    "0xsecure",
		PrivateKey: "0xPRIVATE_KEY_SHOULD_NOT_BE_EXPOSED",
		Mnemonic:   "secret mnemonic phrase should not be exposed",
		PublicKey:  "0xpubkey",
	}

	mockWM.On("GetWallet", "wallet-sec").Return(sensitiveWallet, nil)

	req, err := http.NewRequest("GET", "/wallets/wallet-sec", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	rr := httptest.NewRecorder()
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	// Verify sensitive data is not exposed
	assert.NotContains(t, response, "privateKey")
	assert.NotContains(t, response, "mnemonic")
	
	// Verify public data is present
	assert.Equal(t, "wallet-sec", response["id"])
	assert.Equal(t, "0xsecure", response["address"])
	assert.Equal(t, "0xpubkey", response["publicKey"])

	mockWM.AssertExpectations(t)
}