	require.NoError(t, err)

	assert.Equal(t, "wallet-123", response["walletId"])
	assert.Equal(t, "0xwallet123", response["address"])
	assert.Equal(t, float64(1000000), response["balance"])

	mockWM.AssertExpectations(t)
	mockLed.AssertExpectations(t)
}

func TestAPI_HandleTransferFunds(t *testing.T) {
	apiServer, _, _, mockLed, mockTxPool, mockWM := setupTestAPI(t)

	fromWallet := &wallet.Wallet{
		ID:         "wallet-123",
		Address:    "0xfrom",
		PrivateKey: "0xprivkey",
	}

	// Setup mocks
	mockWM.On("GetWallet", "wallet-123").Return(fromWallet, nil)
	mockLed.On("GetAccount", "0xfrom").Return(common.Account{
		ID:      "0xfrom",
		Balance: 2000000,
		Nonce:   5,
	}, nil)
	mockLed.On("Transfer", "0xfrom", "0xto", uint64(100000)).Return(nil)
	mockTxPool.On("AddTransaction", mock.Anything).Return(nil)
	mockTxPool.On("ValidateTransaction", mock.Anything).Return(nil)

	// Create request body
	reqBody := map[string]interface{}{
		"to":       "0xto",
		"amount":   100000,
		"password": "wallet-password",
	}
	body, _ := json.Marshal(reqBody)

	// Create request
	req, err := http.NewRequest("POST", "/wallets/wallet-123/transfer", bytes.NewBuffer(body))
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")
	req.Header.Set("Content-Type", "application/json")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response map[string]interface{}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, "Transfer initiated successfully", response["message"])
	assert.NotEmpty(t, response["transactionHash"])

	mockWM.AssertExpectations(t)
	mockLed.AssertExpectations(t)
	mockTxPool.AssertExpectations(t)
}

func TestAPI_HandleGetWalletTransactions(t *testing.T) {
	apiServer, mockStore, _, _, mockTxPool, mockWM := setupTestAPI(t)

	testWallet := &wallet.Wallet{
		ID:      "wallet-123",
		Address: "0xwallet123",
	}

	walletTxs := []types.Transaction{
		{
			Hash:   "0xtx1",
			From:   "0xwallet123",
			To:     "0xother",
			Amount: 100,
		},
		{
			Hash:   "0xtx2",
			From:   "0xother",
			To:     "0xwallet123",
			Amount: 200,
		},
	}

	// Setup mocks
	mockWM.On("GetWallet", "wallet-123").Return(testWallet, nil)
	mockTxPool.On("GetTransactionsByAddress", "0xwallet123").Return(walletTxs)

	// Create request
	req, err := http.NewRequest("GET", "/wallets/wallet-123/transactions", nil)
	require.NoError(t, err)
	req.Header.Set("Authorization", "Bearer test-token")

	// Create response recorder
	rr := httptest.NewRecorder()

	// Create router and handle request
	router := mux.NewRouter()
	apiServer.SetupRoutes(router)
	router.ServeHTTP(rr, req)

	// Check response
	assert.Equal(t, http.StatusOK, rr.Code)

	var response struct {
		WalletID     string              `json:"walletId"`
		Address      string              `json:"address"`
		Transactions []types.Transaction `json:"transactions"`
		Count        int                 `json:"count"`
	}
	err = json.Unmarshal(rr.Body.Bytes(), &response)
	require.NoError(t, err)

	assert.Equal(t, "wallet-123", response.WalletID)
	assert.Equal(t, "0xwallet123", response.Address)
	assert.Len(t, response.Transactions, 2)
	assert.Equal(t, 2, response.Count)

	mockWM.AssertExpectations(t)
	mockTxPool.AssertExpectations(t)
}

