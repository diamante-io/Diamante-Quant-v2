// TestStatePruningImpl_GetStateTypePrefix tests getting state type prefixes
func TestStatePruningImpl_GetStateTypePrefix(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Test valid state types
	assert.Equal(t, AccountPrefix, impl.getStateTypePrefix(StateTypeAccount), "Account prefix should match")
	assert.Equal(t, TransactionPrefix, impl.getStateTypePrefix(StateTypeTransaction), "Transaction prefix should match")
	assert.Equal(t, BlockPrefix, impl.getStateTypePrefix(StateTypeBlock), "Block prefix should match")
	assert.Equal(t, ContractPrefix, impl.getStateTypePrefix(StateTypeContract), "Contract prefix should match")
	assert.Equal(t, ContractStoragePrefix, impl.getStateTypePrefix(StateTypeContractStorage), "Contract storage prefix should match")

	// Test invalid state type
	assert.Nil(t, impl.getStateTypePrefix("invalid"), "Invalid state type should return nil")
}

// TestStatePruningImpl_CreateHeightKey tests creating height keys
func TestStatePruningImpl_CreateHeightKey(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Test creating a height key
	prefix := []byte("test:")
	height := uint64(12345)
	key := impl.createHeightKey(prefix, height)

	// Check that the key has the correct prefix
	assert.True(t, bytes.HasPrefix(key, prefix), "Key should have the correct prefix")

	// Check that the key has the correct length
	assert.Equal(t, len(prefix)+8, len(key), "Key should have the correct length")

	// Extract the height from the key
	extractedHeight, err := impl.extractHeightFromKey(key, prefix)
	assert.NoError(t, err, "Extracting height should not return an error")
	assert.Equal(t, height, extractedHeight, "Extracted height should match")
}

// TestStatePruningImpl_ExtractHeightFromKey tests extracting heights from keys
func TestStatePruningImpl_ExtractHeightFromKey(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Test extracting height from a valid key
	prefix := []byte("test:")
	height := uint64(12345)
	key := impl.createHeightKey(prefix, height)

	extractedHeight, err := impl.extractHeightFromKey(key, prefix)
	assert.NoError(t, err, "Extracting height should not return an error")
	assert.Equal(t, height, extractedHeight, "Extracted height should match")

	// Test extracting height from a key with the wrong prefix
	wrongPrefix := []byte("wrong:")
	_, err = impl.extractHeightFromKey(key, wrongPrefix)
	assert.Error(t, err, "Extracting height with wrong prefix should return an error")

	// Test extracting height from a key that's too short
	shortKey := []byte("test:123")
	_, err = impl.extractHeightFromKey(shortKey, prefix)
	assert.Error(t, err, "Extracting height from a short key should return an error")
}

// TestStatePruningImpl_IsCheckpointHeight tests checking if a height is a checkpoint height
func TestStatePruningImpl_IsCheckpointHeight(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	config.CheckpointInterval = 100
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Test checkpoint heights
	assert.True(t, impl.isCheckpointHeight(100), "Height 100 should be a checkpoint height")
	assert.True(t, impl.isCheckpointHeight(200), "Height 200 should be a checkpoint height")
	assert.True(t, impl.isCheckpointHeight(300), "Height 300 should be a checkpoint height")

	// Test non-checkpoint heights
	assert.False(t, impl.isCheckpointHeight(50), "Height 50 should not be a checkpoint height")
	assert.False(t, impl.isCheckpointHeight(150), "Height 150 should not be a checkpoint height")
	assert.False(t, impl.isCheckpointHeight(250), "Height 250 should not be a checkpoint height")

	// Test with checkpoint interval of 0
	config.CheckpointInterval = 0
	assert.False(t, impl.isCheckpointHeight(100), "With interval 0, no height should be a checkpoint height")
}

// TestStatePruningImpl_PruneStateType tests pruning a specific state type
func TestStatePruningImpl_PruneStateType(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	config.CheckpointInterval = 100
	config.MaxPruningBatchSize = 10
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Create some test data
	stateType := StateTypeAccount
	prefix := impl.getStateTypePrefix(stateType)

	// Add some keys to the database directly
	for i := uint64(1); i <= 200; i++ {
		key := impl.createHeightKey(prefix, i)
		value := []byte(fmt.Sprintf("value-%d", i))
		db.data[string(key)] = value
	}

	// Start the pruning manager
	pm.Start()
	defer pm.Stop()

	// Prune up to height 150
	pruned, bytes, err := impl.pruneStateType(stateType, 150)
	assert.NoError(t, err, "Pruning should not return an error")

	// We should have pruned all non-checkpoint heights up to 150
	// That's 150 - (100/100) = 149 entries
	expectedPruned := 149
	assert.Equal(t, expectedPruned, pruned, "Should have pruned the expected number of entries")
	assert.Greater(t, bytes, uint64(0), "Should have reclaimed some bytes")

	// Verify that the checkpoint height was not pruned
	checkpointKey := impl.createHeightKey(prefix, 100)
	_, err = db.Get(checkpointKey)
	assert.NoError(t, err, "Checkpoint key should still exist")

	// Verify that heights above the target were not pruned
	highKey := impl.createHeightKey(prefix, 175)
	_, err = db.Get(highKey)
	assert.NoError(t, err, "Key above target height should still exist")

	// Verify that non-checkpoint heights below the target were pruned
	for i := uint64(1); i < 150; i++ {
		if i == 100 {
			continue // Skip checkpoint
		}
		key := impl.createHeightKey(prefix, i)
		_, err = db.Get(key)
		assert.Error(t, err, "Key below target height should be pruned")
	}
}

// TestStatePruningImpl_PruneState tests pruning all state types
func TestStatePruningImpl_PruneState(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	config.CheckpointInterval = 100
	config.MaxPruningBatchSize = 10
	config.RetentionPolicy = map[string]uint64{
		"account":     50,
		"transaction": 100,
	}
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Create some test data for different state types
	stateTypes := []StateType{StateTypeAccount, StateTypeTransaction}

	for _, stateType := range stateTypes {
		prefix := impl.getStateTypePrefix(stateType)

		// Add some keys to the database directly
		for i := uint64(1); i <= 200; i++ {
			key := impl.createHeightKey(prefix, i)
			value := []byte(fmt.Sprintf("value-%s-%d", stateType, i))
			db.data[string(key)] = value
		}
	}

	// Set the current block height
	pm.currentBlockHeight = 200

	// Start the pruning manager
	pm.Start()
	defer pm.Stop()

	// Prune all state types up to height 150
	err := impl.PruneState(150)
	assert.NoError(t, err, "Pruning should not return an error")

	// Verify that the retention policy was applied correctly
	// For accounts, we should keep up to height 150
	// For transactions, we should keep up to height 100

	// Check accounts
	accountPrefix := impl.getStateTypePrefix(StateTypeAccount)
	for i := uint64(1); i <= 200; i++ {
		key := impl.createHeightKey(accountPrefix, i)
		_, err = db.Get(key)

		if i == 100 || i > 150 {
			// Checkpoint or above target height
			assert.NoError(t, err, "Account key at checkpoint or above target should exist")
		} else {
			// Below target height and not a checkpoint
			assert.Error(t, err, "Account key below target should be pruned")
		}
	}

	// Check transactions
	txPrefix := impl.getStateTypePrefix(StateTypeTransaction)
	for i := uint64(1); i <= 200; i++ {
		key := impl.createHeightKey(txPrefix, i)
		_, err = db.Get(key)

		if i == 100 || i > 150 {
			// Checkpoint or above target height
			assert.NoError(t, err, "Transaction key at checkpoint or above target should exist")
		} else {
			// Below target height and not a checkpoint
			assert.Error(t, err, "Transaction key below target should be pruned")
		}
	}
}

// TestStatePruningImpl_VerifyPruning tests verifying pruning
func TestStatePruningImpl_VerifyPruning(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Create some test data
	stateType := StateTypeAccount
	prefix := impl.getStateTypePrefix(stateType)

	// Add some keys to the database directly
	for i := uint64(151); i <= 200; i++ {
		key := impl.createHeightKey(prefix, i)
		value := []byte(fmt.Sprintf("value-%d", i))
		db.data[string(key)] = value
	}

	// Verify pruning up to height 150
	success, err := impl.VerifyPruning(stateType, 150)
	assert.NoError(t, err, "Verification should not return an error")
	assert.True(t, success, "Verification should succeed")

	// Add a key below the pruned height
	lowKey := impl.createHeightKey(prefix, 100)
	db.data[string(lowKey)] = []byte("value-100")

	// Verify pruning again
	success, err = impl.VerifyPruning(stateType, 150)
	assert.NoError(t, err, "Verification should not return an error")
	assert.False(t, success, "Verification should fail")
}

// TestStatePruningImpl_GetStateTypeStats tests getting state type statistics
func TestStatePruningImpl_GetStateTypeStats(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Create some test data
	stateType := StateTypeAccount
	prefix := impl.getStateTypePrefix(stateType)

	// Add some keys to the database directly
	for i := uint64(100); i <= 200; i++ {
		key := impl.createHeightKey(prefix, i)
		value := []byte(fmt.Sprintf("value-%d", i))
		db.data[string(key)] = value
	}

	// Get statistics
	stats, err := impl.GetStateTypeStats(stateType)
	assert.NoError(t, err, "Getting stats should not return an error")
	assert.NotNil(t, stats, "Stats should not be nil")

	// Check statistics
	assert.Equal(t, 101, stats["count"], "Count should match")
	assert.Equal(t, uint64(100), stats["minHeight"], "Min height should match")
	assert.Equal(t, uint64(200), stats["maxHeight"], "Max height should match")
	assert.Greater(t, stats["totalSize"].(uint64), uint64(0), "Total size should be greater than 0")
	assert.Greater(t, stats["avgSize"].(float64), float64(0), "Average size should be greater than 0")
}

// TestStatePruningManager_PruneStateToHeight verifies that the manager removes
// old data when pruneStateToHeight is called.
func TestStatePruningManager_PruneStateToHeight(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	config.CheckpointInterval = 100
	config.MaxPruningBatchSize = 10
	config.RetentionPolicy = map[string]uint64{
		"account":     50,
		"transaction": 100,
	}
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	impl := storage.NewStatePruningImpl(pm, logger)

	// Populate database with account and transaction entries directly
	for i := uint64(1); i <= 200; i++ {
		accKey := impl.createHeightKey(AccountPrefix, i)
		txKey := impl.createHeightKey(TransactionPrefix, i)
		db.data[string(accKey)] = []byte(fmt.Sprintf("acc-%d", i))
		db.data[string(txKey)] = []byte(fmt.Sprintf("tx-%d", i))
	}

	pm.currentBlockHeight = 200

	err := pm.pruneStateToHeight(150)
	assert.NoError(t, err, "Pruning should not return an error")

	// Verify account entries
	for i := uint64(1); i <= 200; i++ {
		key := impl.createHeightKey(AccountPrefix, i)
		_, err := db.Get(key)

		if i == 100 || i > 150 {
			assert.NoError(t, err, "Account key at checkpoint or above target should exist")
		} else {
			assert.Error(t, err, "Account key below target should be pruned")
		}
	}

	// Verify transaction entries
	for i := uint64(1); i <= 200; i++ {
		key := impl.createHeightKey(TransactionPrefix, i)
		_, err := db.Get(key)

		if i >= 100 {
			assert.NoError(t, err, "Transaction key at or above retention height should exist")
		} else {
			assert.Error(t, err, "Transaction key below retention should be pruned")
		}
	}
}
