// storage/state_pruning_test.go

package storage_test

import (
	"bytes"
	"errors"
	"fmt"
	"sync"
	"testing"
	"time"

	"diamante/storage"
	"github.com/sirupsen/logrus"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/mock"
)

// StateIterator interface for iterating over state entries
type StateIterator interface {
	Next() bool
	Key() []byte
	Value() []byte
	Error() error
	Close()
}

// MockStateDB is a mock implementation of the StateDB interface for testing
type MockStateDB struct {
	mock.Mock
	data     map[string][]byte
	dataLock sync.RWMutex
}

// NewMockStateDB creates a new mock state database
func NewMockStateDB() *MockStateDB {
	return &MockStateDB{
		data: make(map[string][]byte),
	}
}

// Get retrieves a value from the database
func (m *MockStateDB) Get(key []byte) ([]byte, error) {
	m.dataLock.RLock()
	defer m.dataLock.RUnlock()

	args := m.Called(key)
	if args.Get(0) != nil {
		return args.Get(0).([]byte), args.Error(1)
	}

	// If not mocked, use the internal data map
	value, ok := m.data[string(key)]
	if !ok {
		return nil, errors.New("key not found")
	}
	return value, nil
}

// Put stores a key-value pair in the database
func (m *MockStateDB) Put(key, value []byte) error {
	m.dataLock.Lock()
	defer m.dataLock.Unlock()

	args := m.Called(key, value)
	if args.Error(0) != nil {
		return args.Error(0)
	}

	// If not mocked, use the internal data map
	m.data[string(key)] = value
	return nil
}

// Delete removes a key-value pair from the database
func (m *MockStateDB) Delete(key []byte) error {
	m.dataLock.Lock()
	defer m.dataLock.Unlock()

	args := m.Called(key)
	if args.Error(0) != nil {
		return args.Error(0)
	}

	// If not mocked, use the internal data map
	delete(m.data, string(key))
	return nil
}

// MockStateIterator is a mock implementation of the StateIterator interface
type MockStateIterator struct {
	mock.Mock
	keys   [][]byte
	values [][]byte
	index  int
	err    error
}

// NewMockStateIterator creates a new mock state iterator
func NewMockStateIterator(keys [][]byte, values [][]byte, err error) *MockStateIterator {
	return &MockStateIterator{
		keys:   keys,
		values: values,
		index:  -1,
		err:    err,
	}
}

// Next advances the iterator to the next key
func (m *MockStateIterator) Next() bool {
	args := m.Called()
	if args.Bool(0) {
		return args.Bool(0)
	}

	// If not mocked, use the internal implementation
	m.index++
	return m.index < len(m.keys)
}

// Key returns the current key
func (m *MockStateIterator) Key() []byte {
	args := m.Called()
	if args.Get(0) != nil {
		return args.Get(0).([]byte)
	}

	// If not mocked, use the internal implementation
	if m.index < 0 || m.index >= len(m.keys) {
		return nil
	}
	return m.keys[m.index]
}

// Value returns the current value
func (m *MockStateIterator) Value() []byte {
	args := m.Called()
	if args.Get(0) != nil {
		return args.Get(0).([]byte)
	}

	// If not mocked, use the internal implementation
	if m.index < 0 || m.index >= len(m.values) {
		return nil
	}
	return m.values[m.index]
}

// Error returns any accumulated error
func (m *MockStateIterator) Error() error {
	args := m.Called()
	if args.Error(0) != nil {
		return args.Error(0)
	}

	// If not mocked, use the internal implementation
	return m.err
}

// Close releases resources associated with the iterator
func (m *MockStateIterator) Close() {
	m.Called()
}

// NewIterator creates an iterator over a key range
func (m *MockStateDB) NewIterator(start, end []byte) storage.StateIterator {
	args := m.Called(start, end)
	if args.Get(0) != nil {
		return args.Get(0).(StateIterator)
	}

	// If not mocked, create a simple iterator from the data map
	var keys [][]byte
	var values [][]byte

	m.dataLock.RLock()
	defer m.dataLock.RUnlock()

	for k, v := range m.data {
		keyBytes := []byte(k)
		if bytes.Compare(keyBytes, start) >= 0 && (end == nil || bytes.Compare(keyBytes, end) < 0) {
			keys = append(keys, keyBytes)
			values = append(values, v)
		}
	}

	return NewMockStateIterator(keys, values, nil)
}

// Compact runs database compaction on a key range
func (m *MockStateDB) Compact(start, end []byte) error {
	args := m.Called(start, end)
	return args.Error(0)
}

// GetStats returns database statistics
func (m *MockStateDB) GetStats() *storage.StorageStats {
	args := m.Called()
	if args.Get(0) != nil {
		return args.Get(0).(*storage.StorageStats)
	}

	// If not mocked, return some basic stats
	m.dataLock.RLock()
	defer m.dataLock.RUnlock()

	return &storage.StorageStats{
		ConnectionsActive:     1,
		ConnectionsTotal:      1,
		QueriesExecuted:       int64(len(m.data)),
		TransactionsProcessed: 0,
		CacheHitRate:          0.0,
		AverageQueryTime:      0.0,
		ErrorCount:            0,
		LastError:             "",
		UptimeSeconds:         0,
		MemoryUsageMB:         0.0,
	}
}

// Helper function to create a test logger
func createTestLogger() *logrus.Logger {
	logger := logrus.New()
	logger.SetLevel(logrus.DebugLevel)
	return logger
}

// TestStatePruningManager_Creation tests the creation of a state pruning manager
func TestStatePruningManager_Creation(t *testing.T) {
	db := NewMockStateDB()
	config := storage.DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	assert.NotNil(t, pm, "StatePruningManager should not be nil")
	// Cannot test unexported fields - just verify it was created
}

// TestStatePruningManager_StartStop tests starting and stopping the pruning manager
func TestStatePruningManager_StartStop(t *testing.T) {
	db := NewMockStateDB()
	config := storage.DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	assert.NotNil(t, pm, "StatePruningManager should not be nil")

	// Test starting
	err := pm.Start()
	assert.NoError(t, err, "Start should not return an error")
	assert.True(t, pm.running, "Running state should be true after start")

	// Test starting again (should fail)
	err = pm.Start()
	assert.Error(t, err, "Starting an already running manager should return an error")

	// Test stopping
	err = pm.Stop()
	assert.NoError(t, err, "Stop should not return an error")
	assert.False(t, pm.running, "Running state should be false after stop")

	// Test stopping again (should fail)
	err = pm.Stop()
	assert.Error(t, err, "Stopping an already stopped manager should return an error")
}

// TestStatePruningManager_UpdateBlockHeight tests updating the block height
func TestStatePruningManager_UpdateBlockHeight(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	assert.NotNil(t, pm, "StatePruningManager should not be nil")

	// Update block height
	pm.UpdateBlockHeight(100)
	assert.Equal(t, uint64(100), pm.currentBlockHeight, "Block height should be updated")

	// Update to checkpoint height
	pm.UpdateBlockHeight(config.CheckpointInterval)
	assert.Equal(t, config.CheckpointInterval, pm.currentBlockHeight, "Block height should be updated")
	assert.Equal(t, config.CheckpointInterval, pm.lastCheckpoint, "Last checkpoint should be updated")

	// Update to trigger pruning
	pm.Start()
	pm.UpdateBlockHeight(config.BlocksToKeep + config.PruningInterval)
	// Wait a bit for the pruning to be triggered
	time.Sleep(100 * time.Millisecond)
	pm.Stop()
}

// TestStatePruningManager_GetMetrics tests getting metrics
func TestStatePruningManager_GetMetrics(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	assert.NotNil(t, pm, "StatePruningManager should not be nil")

	// Get initial metrics
	metrics := pm.GetMetrics()
	assert.Equal(t, uint64(0), metrics.TotalPruningRuns, "Initial total pruning runs should be 0")
	assert.Equal(t, uint64(0), metrics.TotalEntriesPruned, "Initial total entries pruned should be 0")
	assert.Equal(t, uint64(0), metrics.TotalBytesReclaimed, "Initial total bytes reclaimed should be 0")
	assert.Equal(t, uint64(0), metrics.PruningErrors, "Initial pruning errors should be 0")

	// Update metrics
	pm.mu.Lock()
	pm.metrics.TotalPruningRuns = 1
	pm.metrics.TotalEntriesPruned = 100
	pm.metrics.TotalBytesReclaimed = 1024
	pm.metrics.PruningErrors = 2
	pm.mu.Unlock()

	// Get updated metrics
	metrics = pm.GetMetrics()
	assert.Equal(t, uint64(1), metrics.TotalPruningRuns, "Updated total pruning runs should be 1")
	assert.Equal(t, uint64(100), metrics.TotalEntriesPruned, "Updated total entries pruned should be 100")
	assert.Equal(t, uint64(1024), metrics.TotalBytesReclaimed, "Updated total bytes reclaimed should be 1024")
	assert.Equal(t, uint64(2), metrics.PruningErrors, "Updated pruning errors should be 2")
}

// TestStatePruningManager_GetConfig tests getting the configuration
func TestStatePruningManager_GetConfig(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	assert.NotNil(t, pm, "StatePruningManager should not be nil")

	// Get the config
	retrievedConfig := pm.GetConfig()
	assert.Equal(t, config.Policy, retrievedConfig.Policy, "Policy should match")
	assert.Equal(t, config.BlocksToKeep, retrievedConfig.BlocksToKeep, "BlocksToKeep should match")
	assert.Equal(t, config.CheckpointInterval, retrievedConfig.CheckpointInterval, "CheckpointInterval should match")
	assert.Equal(t, config.PruningInterval, retrievedConfig.PruningInterval, "PruningInterval should match")
	assert.Equal(t, config.MaxPruningBatchSize, retrievedConfig.MaxPruningBatchSize, "MaxPruningBatchSize should match")
	assert.Equal(t, config.EnableCompaction, retrievedConfig.EnableCompaction, "EnableCompaction should match")
	assert.Equal(t, config.CompactionThreshold, retrievedConfig.CompactionThreshold, "CompactionThreshold should match")

	// Check that the retention policy was deep copied
	assert.Equal(t, len(config.RetentionPolicy), len(retrievedConfig.RetentionPolicy), "RetentionPolicy length should match")
	for k, v := range config.RetentionPolicy {
		assert.Equal(t, v, retrievedConfig.RetentionPolicy[k], "RetentionPolicy values should match")
	}

	// Modify the retrieved config and check that the original is unchanged
	retrievedConfig.BlocksToKeep = 999
	assert.NotEqual(t, config.BlocksToKeep, retrievedConfig.BlocksToKeep, "Original config should not be affected by changes to the retrieved config")
}

// TestStatePruningManager_UpdateConfig tests updating the configuration
func TestStatePruningManager_UpdateConfig(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
	assert.NotNil(t, pm, "StatePruningManager should not be nil")

	// Create a new config
	newConfig := &PruningConfig{
		Policy:              FullPruning,
		BlocksToKeep:        5000,
		CheckpointInterval:  500,
		PruningInterval:     50,
		MaxPruningBatchSize: 500,
		EnableCompaction:    false,
		CompactionThreshold: 5000,
		RetentionPolicy: map[string]uint64{
			"accounts":     25000,
			"transactions": 50000,
		},
	}

	// Update the config
	err := pm.UpdateConfig(newConfig)
	assert.NoError(t, err, "UpdateConfig should not return an error")

	// Get the updated config
	retrievedConfig := pm.GetConfig()
	assert.Equal(t, newConfig.Policy, retrievedConfig.Policy, "Policy should match")
	assert.Equal(t, newConfig.BlocksToKeep, retrievedConfig.BlocksToKeep, "BlocksToKeep should match")
	assert.Equal(t, newConfig.CheckpointInterval, retrievedConfig.CheckpointInterval, "CheckpointInterval should match")
	assert.Equal(t, newConfig.PruningInterval, retrievedConfig.PruningInterval, "PruningInterval should match")
	assert.Equal(t, newConfig.MaxPruningBatchSize, retrievedConfig.MaxPruningBatchSize, "MaxPruningBatchSize should match")
	assert.Equal(t, newConfig.EnableCompaction, retrievedConfig.EnableCompaction, "EnableCompaction should match")
	assert.Equal(t, newConfig.CompactionThreshold, retrievedConfig.CompactionThreshold, "CompactionThreshold should match")

	// Check that the retention policy was updated
	assert.Equal(t, len(newConfig.RetentionPolicy), len(retrievedConfig.RetentionPolicy), "RetentionPolicy length should match")
	for k, v := range newConfig.RetentionPolicy {
		assert.Equal(t, v, retrievedConfig.RetentionPolicy[k], "RetentionPolicy values should match")
	}

	// Test invalid config (nil)
	err = pm.UpdateConfig(nil)
	assert.Error(t, err, "UpdateConfig with nil config should return an error")

	// Test invalid config (BlocksToKeep < CheckpointInterval)
	invalidConfig := &PruningConfig{
		BlocksToKeep:       100,
		CheckpointInterval: 200,
	}
	err = pm.UpdateConfig(invalidConfig)
	assert.Error(t, err, "UpdateConfig with invalid config should return an error")
}

// TestStatePruningImpl_Creation tests the creation of a state pruning implementation
func TestStatePruningImpl_Creation(t *testing.T) {
	db := NewMockStateDB()
	config := DefaultPruningConfig()
	logger := createTestLogger()

	pm := storage.NewStatePruningManager(db, config, logger)
