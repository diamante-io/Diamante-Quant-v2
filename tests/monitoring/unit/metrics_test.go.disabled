// Test the new typed metrics collector

func TestNewTypedMetricsCollector(t *testing.T) {
	logger := logrus.New()
	logger.SetLevel(logrus.ErrorLevel)

	config := &monitoring.MetricsConfig{
		EnablePrometheus:  true,
		EnableBusiness:    true,
		EnablePerformance: true,
		PrometheusPort:    9090,
		CollectInterval:   30 * time.Second,
	}

	collector := monitoring.NewMetricsCollector(config, logger)
	require.NotNil(t, collector)
}

func TestTypedMetricsCollectorStartStop(t *testing.T) {
	logger := logrus.New()
	logger.SetLevel(logrus.ErrorLevel)

	config := &monitoring.MetricsConfig{
		EnablePrometheus:  false, // Disable server for testing
		EnableBusiness:    true,
		EnablePerformance: true,
		CollectInterval:   100 * time.Millisecond,
	}

	collector := monitoring.NewMetricsCollector(config, logger)
	require.NotNil(t, collector)

	ctx, cancel := context.WithTimeout(context.Background(), 1*time.Second)
	defer cancel()

	// Test start
	err := collector.Start(ctx)
	require.NoError(t, err)

	// Test stop
	err = collector.Stop()
	require.NoError(t, err)
}

func TestTypedMetricsCollectorRecording(t *testing.T) {
	logger := logrus.New()
	logger.SetLevel(logrus.ErrorLevel)

	config := &monitoring.MetricsConfig{
		EnablePrometheus:  false,
		EnableBusiness:    true,
		EnablePerformance: true,
		CollectInterval:   1 * time.Second,
	}

	collector := monitoring.NewMetricsCollector(config, logger)
	require.NotNil(t, collector)

	// Test transaction metrics recording
	tx := &types.TypedTransaction{
		Hash: "test-hash",
		Type: "transfer",
	}

	collector.RecordTransactionMetrics(tx, "success", 100*time.Millisecond)

	// Test block metrics recording
	collector.RecordBlockMetrics(1000, 1024, 50*time.Millisecond, "success")

	// Test consensus metrics recording
	collector.RecordConsensusMetrics("success", 200*time.Millisecond, 10)

	// Test counter operations
	collector.IncrementCounter("test_counter", map[string]string{"component": "test"})

	// Test gauge operations
	collector.SetGauge("test_gauge", 42.0, map[string]string{"component": "test"})

	// Test histogram operations
	collector.ObserveHistogram("test_histogram", 1.5, map[string]string{"component": "test"})

	// Should complete without panics
}

func TestTypedMetricsCollectorGetMetrics(t *testing.T) {
	logger := logrus.New()
	logger.SetLevel(logrus.ErrorLevel)

	config := &monitoring.MetricsConfig{
		EnablePrometheus:  false,
		EnableBusiness:    true,
		EnablePerformance: true,
		CollectInterval:   1 * time.Second,
	}

	collector := monitoring.NewMetricsCollector(config, logger)
	require.NotNil(t, collector)

	// Record some metrics
	collector.IncrementCounter("test_counter", map[string]string{"test": "value"})
	collector.SetGauge("test_gauge", 123.45, map[string]string{"test": "value"})

	// Get metrics
	metrics, err := collector.GetMetrics()
	require.NoError(t, err)
	require.NotNil(t, metrics)

	// Should contain our metrics
	assert.Contains(t, metrics, "counters")
	assert.Contains(t, metrics, "gauges")
	assert.Contains(t, metrics, "histograms")
}

// Benchmark tests

func BenchmarkNewMetrics(b *testing.B) {
	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		metrics := monitoring.NewMetrics()
		_ = metrics
	}
}

func BenchmarkMetricsOperations(b *testing.B) {
	metrics := monitoring.NewMetrics()

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		metrics.ConsensusHeight.Set(float64(i))
		metrics.TxProcessed.Inc()
		metrics.ConsensusLatency.Observe(0.1)
	}
}

func BenchmarkMetricsCollectorCollection(b *testing.B) {
	logger := logrus.New()
	logger.SetLevel(logrus.ErrorLevel)

	consensus := &MockConsensus{height: 1000}
	network := &MockNetwork{peerCount: 10}
	ledger := &MockLedger{}
	txMgr := &MockTransactionManager{poolSize: 25}

	collector := monitoring.NewMetricsCollector(
		consensus,
		network,
		ledger,
		txMgr,
		1*time.Second,
		logger,
	)

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		// Simulate what the internal collect() method does
		_ = consensus.GetLastBlockHeight()
		_ = len(consensus.GetActiveValidators())
		_ = len(consensus.GetValidators())
		_ = txMgr.GetPoolSize()
		_ = txMgr.GetStats()
	}
}

func TestDefaultMetricsConfig(t *testing.T) {
	config := monitoring.DefaultMetricsConfig()
	require.NotNil(t, config)

	assert.True(t, config.EnablePrometheus)
	assert.True(t, config.EnableBusiness)
	assert.True(t, config.EnablePerformance)
	assert.Equal(t, 9090, config.PrometheusPort)
	assert.Equal(t, 30*time.Second, config.CollectInterval)
}