// TestValidatorStateManagement tests state save and restore
func TestValidatorStateManagement(t *testing.T) {
	config := consensus.TestHybridConfig()
	hc := consensus.NewHybridConsensusWithConfig(config)
	require.NotNil(t, hc)

	vm := hc.GetValidatorManager()
	require.NotNil(t, vm)

	// Add validators
	validators := make([][32]byte, 3)
	stakes := []uint64{1000000, 2000000, 3000000}

	for i := range validators {
		validators[i] = generateValidatorID(i)
		err := vm.AddValidator(validators[i], stakes[i])
		require.NoError(t, err)

		// Activate validator
		err = vm.ActivateValidator(validators[i])
		require.NoError(t, err)
	}

	// Get current state
	state, err := vm.GetState()
	require.NoError(t, err, "GetState should not error")
	require.NotEmpty(t, state, "State should not be empty")

	// Create a new ValidatorManager and restore state
	newHC := consensus.NewHybridConsensusWithConfig(config)
	newVM := newHC.GetValidatorManager()

	err = newVM.RestoreState(state)
	assert.NoError(t, err, "RestoreState should not error")

	// Verify validators were restored
	restoredValidators := newVM.GetValidators()
	assert.Equal(t, len(validators), len(restoredValidators), "Should restore all validators")

	// Verify stakes were restored correctly
	for i, v := range validators {
		found := false
		for _, restored := range restoredValidators {
			if restored.ID == v {
				found = true
				assert.Equal(t, stakes[i], restored.Stake, "Restored stake should match")
				break
			}
		}
		assert.True(t, found, "Validator should be restored")
	}
}

// TestConcurrentValidatorOperations tests thread safety
func TestConcurrentValidatorOperations(t *testing.T) {
	config := consensus.TestHybridConfig()
	hc := consensus.NewHybridConsensusWithConfig(config)
	require.NotNil(t, hc)

	vm := hc.GetValidatorManager()
	require.NotNil(t, vm)

	// Run concurrent operations
	done := make(chan bool, 4)

	// Goroutine 1: Add validators
	go func() {
		for i := 0; i < 10; i++ {
			validatorID := generateValidatorID(i)
			_ = vm.AddValidator(validatorID, uint64(1000000+i*100000))
			time.Sleep(5 * time.Millisecond)
		}
		done <- true
	}()

	// Goroutine 2: Update stakes
	go func() {
		time.Sleep(10 * time.Millisecond) // Let some validators be added first
		for i := 0; i < 5; i++ {
			validatorID := generateValidatorID(i)
			_ = vm.UpdateStake(validatorID, uint64(2000000+i*200000))
			time.Sleep(10 * time.Millisecond)
		}
		done <- true
	}()

	// Goroutine 3: Get validators
	go func() {
		for i := 0; i < 20; i++ {
			validators := vm.GetValidators()
			assert.NotNil(t, validators)
			time.Sleep(5 * time.Millisecond)
		}
		done <- true
	}()

	// Goroutine 4: Check active status
	go func() {
		for i := 0; i < 20; i++ {
			validatorID := generateValidatorID(i % 10)
			_ = vm.IsActiveValidator(validatorID)
			time.Sleep(5 * time.Millisecond)
		}
		done <- true
	}()

	// Wait for all goroutines
	for i := 0; i < 4; i++ {
		select {
		case <-done:
			// Success
		case <-time.After(5 * time.Second):
			t.Fatal("Concurrent operations timed out")
		}
	}
}

// TestValidatorRotation tests validator rotation logic
func TestValidatorRotation(t *testing.T) {
	config := consensus.TestHybridConfig()
	config.DPoSSetSize = 3 // Small set size for testing rotation
	hc := consensus.NewHybridConsensusWithConfig(config)
	require.NotNil(t, hc)

	vm := hc.GetValidatorManager()
	require.NotNil(t, vm)

	// Add more validators than set size
	validators := make([][32]byte, 6)
	for i := range validators {
		validators[i] = generateValidatorID(i)
		// Give different stakes to ensure deterministic selection
		stake := uint64(1000000 * (len(validators) - i))
		err := vm.AddValidator(validators[i], stake)
		require.NoError(t, err)
	}

	// Get active validators
	activeValidators := vm.GetActiveValidators()
	assert.LessOrEqual(t, len(activeValidators), config.DPoSSetSize,
		"Active validators should not exceed set size")

	// Verify highest stake validators are active
	// (This assumes the implementation selects by stake)
	t.Logf("Active validators count: %d", len(activeValidators))
}

