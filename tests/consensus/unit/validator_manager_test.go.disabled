// BenchmarkAddValidator benchmarks validator addition
func BenchmarkAddValidator(b *testing.B) {
	config := consensus.TestHybridConfig()
	hc := consensus.NewHybridConsensusWithConfig(config)
	vm := hc.GetValidatorManager()

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		validatorID := generateValidatorID(i)
		_ = vm.AddValidator(validatorID, uint64(1000000+i*1000))
	}
}

// BenchmarkGetNextValidator benchmarks validator selection
func BenchmarkGetNextValidator(b *testing.B) {
	config := consensus.TestHybridConfig()
	hc := consensus.NewHybridConsensusWithConfig(config)
	vm := hc.GetValidatorManager()

	// Add validators
	for i := 0; i < 100; i++ {
		validatorID := generateValidatorID(i)
		_ = vm.AddValidator(validatorID, uint64(1000000+i*10000))
	}

	var lastBlockHash [32]byte
	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		_ = vm.GetNextValidator(uint64(i), lastBlockHash)
	}
}

// BenchmarkGetAllValidators benchmarks retrieving all validators
func BenchmarkGetAllValidators(b *testing.B) {
	config := consensus.TestHybridConfig()
	hc := consensus.NewHybridConsensusWithConfig(config)
	vm := hc.GetValidatorManager()

	// Add many validators
	for i := 0; i < 1000; i++ {
		validatorID := generateValidatorID(i)
		_ = vm.AddValidator(validatorID, uint64(1000000+i*1000))
	}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		_ = vm.GetValidators()
	}
}

// TestValidatorMetrics tests validator performance metrics
func TestValidatorMetrics(t *testing.T) {
	config := consensus.TestHybridConfig()
	hc := consensus.NewHybridConsensusWithConfig(config)
	require.NotNil(t, hc)

	vm := hc.GetValidatorManager()
	require.NotNil(t, vm)

	// Add validators and simulate activity
	validators := make([][32]byte, 3)
	for i := range validators {
		validators[i] = generateValidatorID(i)
		err := vm.AddValidator(validators[i], uint64(1000000+i*500000))
		require.NoError(t, err)
	}

	// Simulate block production and event finalization
	for i := 0; i < 10; i++ {
		validatorIdx := i % len(validators)
		_ = vm.RewardBlockProduction(validators[validatorIdx], uint64(i+1))
		_ = vm.RewardEventFinalization(validators[validatorIdx], uint64(i+1))
	}

	// Get metrics (if available)
	// This is a placeholder for when metrics are implemented
	t.Log("Metrics test placeholder - implement when metrics are available")
}

