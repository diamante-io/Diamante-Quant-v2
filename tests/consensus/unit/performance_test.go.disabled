func TestPerformanceOptimizer_Creation(t *testing.T) {
	logger := newHybridConsensusLogger()
	config := DefaultOptimizerConfig()

	optimizer := NewPerformanceOptimizer(config, logger)
	assert.NotNil(t, optimizer)
	assert.Equal(t, config, optimizer.config)
	// Don't check the pools directly to avoid copying sync.Pool
	// Just verify the optimizer was created successfully
	assert.NotNil(t, optimizer.workerPool)
}

func TestPerformanceOptimizer_StartStop(t *testing.T) {
	logger := newHybridConsensusLogger()
	optimizer := NewPerformanceOptimizer(nil, logger)

	// Test start
	err := optimizer.Start()
	require.NoError(t, err)

	// Test double start
	err = optimizer.Start()
	require.Error(t, err)
	assert.Contains(t, err.Error(), "already running")

	// Test stop
	err = optimizer.Stop()
	require.NoError(t, err)

	// Test double stop
	err = optimizer.Stop()
	require.NoError(t, err) // Should not error
}

func TestPerformanceOptimizer_MemoryPools(t *testing.T) {
	logger := newHybridConsensusLogger()
	optimizer := NewPerformanceOptimizer(nil, logger)

	// Test event pool
	event1 := optimizer.GetEvent()
	assert.NotNil(t, event1)

	event2 := optimizer.GetEvent()
	assert.NotNil(t, event2)
	assert.NotEqual(t, event1, event2) // Should be different instances

	// Return events to pool
	optimizer.PutEvent(event1)
	optimizer.PutEvent(event2)

	// Test block pool
	block1 := optimizer.GetBlock()
	assert.NotNil(t, block1)

	block2 := optimizer.GetBlock()
	assert.NotNil(t, block2)

	optimizer.PutBlock(block1)
	optimizer.PutBlock(block2)

	// Test validator pool
	validator1 := optimizer.GetValidator()
	assert.NotNil(t, validator1)

	optimizer.PutValidator(validator1)
}

func TestPerformanceOptimizer_Cache(t *testing.T) {
	logger := newHybridConsensusLogger()
	optimizer := NewPerformanceOptimizer(nil, logger)

	eventID := [32]byte{1, 2, 3}
	event := optimizer.GetEvent()
	event.ID = eventID

	// Test cache miss
	cached, found := optimizer.GetCachedEvent(eventID)
	assert.False(t, found)
	assert.Nil(t, cached)

	// Cache the event
	optimizer.CacheEvent(eventID, event)

	// Test cache hit
	cached, found = optimizer.GetCachedEvent(eventID)
	assert.True(t, found)
	assert.NotNil(t, cached)
	assert.Equal(t, eventID, cached.ID)
}

func TestPerformanceOptimizer_TaskSubmission(t *testing.T) {
	logger := newHybridConsensusLogger()
	optimizer := NewPerformanceOptimizer(nil, logger)

	err := optimizer.Start()
	require.NoError(t, err)
	defer optimizer.Stop()

	// Test task submission
	executed := false
	task := SimpleTask{
		Fn: func() {
			executed = true
		},
	}

	err = optimizer.SubmitTask(task)
	require.NoError(t, err)

	// Wait for task execution
	time.Sleep(100 * time.Millisecond)
	assert.True(t, executed)
}

